{
  "manifest_version": 3,
  "name": "open-demo",
  "version": "1.0.0",
  "description": "Free open-source Scribe alternative for creating step-by-step guides from browser interactions",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://od.salandru.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon-black-16.png",
    "32": "icons/icon-black-32.png",
    "48": "icons/icon-black-48.png",
    "128": "icons/icon-black-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "open-demo",
    "default_icon": {
      "16": "icons/icon-black-16.png",
      "32": "icons/icon-black-32.png",
      "48": "icons/icon-black-48.png",
      "128": "icons/icon-black-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "editor/editor.html",
        "editor/editor.js",
        "editor/editor.css"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
